---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Home/Hero.astro";
import QuickPrompt from "../components/Home/QuickPrompt.astro";
import TutorialGrid from "../components/Home/TutorialGrid.astro";
import DiscoverGrid from "../components/Home/DiscoverGrid.astro";
import EarnSection from "../components/Home/EarnSection.astro";
import CommunitySection from "../components/Home/CommunitySection.astro";
import FinalCTA from "../components/Home/FinalCTA.astro";
---

<MainLayout>
	<Hero />
	<QuickPrompt />
	<TutorialGrid />
	<DiscoverGrid />
	<EarnSection />
	<CommunitySection />
	<FinalCTA />

</MainLayout>

<style>
  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #08000f;
    color: white;
  }

  .page {

    background:
      radial-gradient(circle at top right, rgba(255, 20, 147, 0.35), transparent 35%),
      radial-gradient(circle at bottom left, rgba(120, 70, 255, 0.25), transparent 30%),
      #08000f;
	  padding-bottom: 40px;
  }

  
  h1 {
    font-size: 64px;
    line-height: 1.05;
    margin: 0;
  }



  .buttons a {
    text-decoration: none;
    padding: 14px 22px;
    border-radius: 12px;
    font-weight: bold;
  }

  .primary {
    background: #ff1493;
    color: white;
  }

  .secondary {
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
  }

  .section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 35px 24px;
  }

  .section h2 {
    font-size: 36px;
    margin-bottom: 28px;
  }

  .cards,
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

	.card,
	.steps div{
		background:rgba(255,255,255,.08);
		border:1px solid rgba(255,255,255,.12);
		border-radius:20px;
		padding:24px;
	}

	.card{
		min-height: 130px;
		display:block;
		text-decoration:none;
		color:white;
		transition:.25s;
	}
	.card span {
		font-size: 28px;
		display: block;
		margin-bottom: 14px;
}

	.card:hover{
		transform:translateY(-5px);
		border-color:#ff1493;
	}
  .steps span {
    color: #ff4fc3;
    font-weight: bold;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 42px;
    }

    .cards,
    .steps {
      grid-template-columns: 1fr;
    }

    .buttons {
      flex-direction: column;
    }
  }
</style>